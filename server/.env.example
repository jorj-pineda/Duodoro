PORT=3001

# Set this to your Vercel deployment URL in production (no trailing slash)
# Example: ALLOWED_ORIGIN=https://duodoro.vercel.app
ALLOWED_ORIGIN=http://localhost:3000

# Supabase — find these in your Supabase dashboard > Settings > API
# Use the SERVICE ROLE key (not the anon key) — this bypasses RLS for server-side writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
